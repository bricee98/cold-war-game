NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional role mapping for auth users (comma-separated, case-insensitive)
NEXT_PUBLIC_GM_EMAILS=
NEXT_PUBLIC_USA_EMAILS=
NEXT_PUBLIC_USSR_EMAILS=
NEXT_PUBLIC_FINLAND_EMAILS=

# Optional UID mappings (useful when email is hidden)
NEXT_PUBLIC_GM_UIDS=
NEXT_PUBLIC_USA_UIDS=
NEXT_PUBLIC_USSR_UIDS=
NEXT_PUBLIC_FINLAND_UIDS=

# Server-side AI (private assistant)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_SUMMARY_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=high
OPENAI_MAX_OUTPUT_TOKENS=2000
OPENAI_MAX_CONTINUATIONS=3
