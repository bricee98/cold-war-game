rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /games/{gameId} {
      allow read, write: if signedIn();

      match /{document=**} {
        allow read, write: if signedIn();
      }
    }
  }
}
